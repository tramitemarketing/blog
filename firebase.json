{
  "hosting": {
    "public": "out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/articoli/*/",
        "destination": "/articoli/articolo/index.html"
      },
      {
        "source": "/admin/articoli/*/",
        "destination": "/admin/articoli/placeholder/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(svg|jpg|jpeg|gif|png|webp)",
        "headers": [
          { "key": "Cache-Control", "value": "max-age=86400" }
        ]
      }
    ]
  }
}
